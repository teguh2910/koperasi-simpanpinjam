{
    "name": "koperasi/simpanpinjam",
    "description": "Koperasi Simpan Pinjam Application",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "laravel/framework": "^13.0",
        "jeroennoten/laravel-adminlte": "^3.16"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "phpunit/phpunit": "^11.0",
        "nunomaduro/collision": "^8.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "composer/package-versions-optimal-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}